---
const { projects, heading = 'Проекти' } = Astro.props;
---

<section class="projects-section" aria-labelledby="projects-heading">
	<div class="container">
		<h2 id="projects-heading" class="projects-section__title">{heading}</h2>
		<div class="projects-grid" role="list">
			{
				projects.map((project, index) => (
					<button
						type="button"
						class="project-card"
						role="listitem"
						data-project-id={project.id}
						aria-haspopup="dialog"
						style={`--reveal-delay: ${index * 55}ms`}
					>
						<img
							class="project-card__img"
							src={project.cover}
							alt=""
							loading="lazy"
							decoding="async"
							fetchpriority="low"
						/>
						<span class="project-card__inner">
							<span class="project-card__title">{project.title}</span>
							<span class="project-card__desc">{project.description}</span>
						</span>
					</button>
				))
			}
		</div>
	</div>
</section>

<dialog class="project-modal" id="project-modal" aria-labelledby="project-modal-title">
	<div class="project-modal__shell">
		<header class="project-modal__header">
			<div class="project-modal__intro">
				<h2 id="project-modal-title" class="project-modal__heading"></h2>
				<p id="project-modal-description" class="project-modal__description"></p>
			</div>
			<button type="button" class="project-modal__close" aria-label="Затвори">
				<span aria-hidden="true">&times;</span>
			</button>
		</header>
		<div class="swiper project-modal__swiper" id="project-gallery-swiper">
			<div class="swiper-wrapper"></div>
			<div class="swiper-button-prev" aria-label="Предишна снимка"></div>
			<div class="swiper-button-next" aria-label="Следваща снимка"></div>
			<div class="swiper-pagination"></div>
		</div>
	</div>
</dialog>

<style>
	.projects-section {
		padding: 6rem 0 8rem;
	}

	.projects-section__title {
		font-size: clamp(3.2rem, 5vw, 5rem);
		color: var(--coor-headings);
		margin-bottom: 3rem;
		text-align: center;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.6rem;
	}

	@media (min-width: 768px) {
		.projects-grid {
			grid-template-columns: repeat(3, 1fr);
			gap: 2rem;
		}
	}

	.project-card {
		position: relative;
		display: block;
		width: 100%;
		aspect-ratio: 1;
		padding: 0;
		text-align: left;
		border: none;
		border-radius: var(--border-radius);
		overflow: hidden;
		cursor: pointer;
		background-color: #1a1a1a;
		color: var(--color-light);
		opacity: 0;
		transform: translateY(1.6rem);
		/* Stagger only the scroll-in; box-shadow delay must stay 0 or hover feels “late” */
		transition-property: opacity, transform, box-shadow;
		transition-duration: 0.65s, 0.65s, 0.2s;
		transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1), cubic-bezier(0.22, 1, 0.36, 1), ease;
		transition-delay: var(--reveal-delay, 0s), var(--reveal-delay, 0s), 0s;
	}

	.project-card.project-card--visible {
		opacity: 1;
		transform: translateY(0);
	}

	.project-card.project-card--visible:hover,
	.project-card.project-card--visible:focus-visible {
		box-shadow: 0 12px 32px var(--color-primary);
	}

	@media (prefers-reduced-motion: reduce) {
		.project-card {
			opacity: 1;
			transform: none;
			transition: box-shadow 0.2s ease;
			transition-delay: 0ms;
		}

		.project-card.project-card--visible:hover,
		.project-card.project-card--visible:focus-visible {
			transform: none;
		}
	}

	.project-card__img {
		position: absolute;
		inset: 0;
		z-index: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		pointer-events: none;
	}

	.project-card::before {
		content: '';
		position: absolute;
		inset: 0;
		z-index: 1;
		background: linear-gradient(
			to top,
			rgba(0, 0, 0, 0.88) 0%,
			rgba(0, 0, 0, 0.35) 45%,
			rgba(0, 0, 0, 0.2) 100%
		);
		pointer-events: none;
	}

	.project-card__inner {
		position: absolute;
		inset: 0;
		z-index: 2;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		align-items: stretch;
		padding: 1.6rem;
		gap: 0.6rem;
		box-sizing: border-box;
	}

	.project-card__title {
		font-size: 1.8rem;
		font-weight: 700;
		line-height: 1.25;
		text-shadow: 0 1px 8px rgba(0, 0, 0, 0.6);
	}

	.project-card__desc {
		font-size: 1.4rem;
		line-height: 1.4;
		opacity: 0.95;
		text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.project-modal {
		padding: 0;
		border: none;
		border-radius: var(--border-radius);
		background: var(--color-light);
		box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
	}

	/* Reliable viewport centering (native dialog + margin:auto is inconsistent on small screens) */
	.project-modal[open] {
		position: fixed;
		inset: 0;
		margin: auto;
		width: min(96vw, 960px);
		max-width: calc(100vw - 1.5rem);
		height: fit-content;
		max-height: min(92vh, calc(100dvh - 2rem));
	}

	.project-modal::backdrop {
		background: rgba(0, 0, 0, 0.65);
	}

	.project-modal__shell {
		display: flex;
		flex-direction: column;
		padding-inline: 2rem;
		max-height: 92vh;
	}

	.project-modal__header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		padding-block: 1.4rem;
		border-bottom: 1px solid #e5e5e5;
		flex-shrink: 0;
	}

	.project-modal__intro {
		min-width: 0;
		flex: 1;
		padding-right: 0.5rem;
	}

	.project-modal__heading {
		font-size: 2rem;
		margin: 0;
		color: var(--color-dark);
		line-height: 1.2;
	}

	.project-modal__description {
		margin: 0.6rem 0 0;
		font-size: 1.5rem;
		line-height: 1.45;
		color: #444;
	}

	.project-modal__description:empty {
		display: none;
	}

	.project-modal__close {
		flex-shrink: 0;
		width: 4rem;
		height: 4rem;
		display: grid;
		place-items: center;
		font-size: 2.8rem;
		line-height: 1;
		color: var(--color-dark);
		border-radius: var(--border-radius);
		transition: background 0.15s ease;
	}

	.project-modal__close:hover,
	.project-modal__close:focus-visible {
		background: #f0f0f0;
		outline: 2px solid var(--color-primary);
		outline-offset: 2px;
	}

	.project-modal__swiper {
		width: 100%;
		max-width: 100%;
		padding: 0 0 3.2rem;
		box-sizing: border-box;
		overflow: hidden;
	}

	.project-modal__swiper :global(.swiper-wrapper) {
		box-sizing: border-box;
	}

	.project-modal__swiper :global(.swiper-slide) {
		display: flex;
		align-items: center;
		justify-content: center;
		background: #111;
		border-radius: var(--border-radius);
		overflow: hidden;
		width: 100% !important;
		max-width: 100%;
		height: auto;
		box-sizing: border-box;
		flex-shrink: 0;
	}

	/* Natural height per slide; cap keeps dialog inside viewport (Swiper autoHeight reads this box) */
	.project-modal__swiper :global(.swiper-slide img) {
		display: block;
		width: 100%;
		height: auto;
		max-height: min(75vh, calc(100vh - 14rem));
		max-height: min(75dvh, calc(100dvh - 14rem));
		object-fit: contain;
	}

	.project-modal__swiper :global(.swiper-button-prev),
	.project-modal__swiper :global(.swiper-button-next) {
		color: var(--color-primary);
		top: 50%;
		margin-top: 0;
		transform: translateY(-50%);
		z-index: 2;
		/* White halo + slight dark shadow so arrows read on any slide */
		filter: drop-shadow(0 0 1px #fff)
			drop-shadow(0 0 2px #fff)
			drop-shadow(0 0 5px rgba(255, 255, 255, 0.9))
			drop-shadow(0 1px 2px rgba(0, 0, 0, 0.45));
	}

	.project-modal__swiper :global(.swiper-button-prev) {
		left: 0.4rem;
	}

	.project-modal__swiper :global(.swiper-button-next) {
		right: 0.4rem;
	}

	@media (min-width: 600px) {
		.project-modal__swiper :global(.swiper-button-prev) {
			left: 0.8rem;
		}

		.project-modal__swiper :global(.swiper-button-next) {
			right: 0.8rem;
		}
	}

	.project-modal__swiper :global(.swiper-pagination-bullet-active) {
		background: var(--color-primary);
	}
</style>

<!-- `define:vars` + `import` in one tag is emitted without type="module" and breaks in the browser. -->
<script define:vars={{ projects }}>
	globalThis.__SOLARG_PROJECTS_GRID__ = projects;
</script>

<script>
	import Swiper from 'swiper';
	import { Navigation, Pagination, Keyboard, A11y, EffectFade } from 'swiper/modules';
	import 'swiper/css';
	import 'swiper/css/navigation';
	import 'swiper/css/pagination';
	import 'swiper/css/effect-fade';

	const projects = globalThis.__SOLARG_PROJECTS_GRID__;
	if (!Array.isArray(projects)) {
		throw new Error('ProjectsGrid: missing __SOLARG_PROJECTS_GRID__');
	}

	const projectById = Object.fromEntries(projects.map((p) => [p.id, p]));

	let cardsRevealObserver = null;

	function initProjectCardsReveal() {
		const section = document.querySelector('.projects-section');
		if (!section) return;

		const cards = section.querySelectorAll('.project-card[data-project-id]');
		if (!cards.length) return;

		cardsRevealObserver?.disconnect();
		cardsRevealObserver = null;

		const revealAll = () => {
			cards.forEach((c) => c.classList.add('project-card--visible'));
		};

		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			revealAll();
			return;
		}

		const io = new IntersectionObserver(
			(entries, obs) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					entry.target.classList.add('project-card--visible');
					obs.unobserve(entry.target);
				});
			},
			{ root: null, rootMargin: '80px 0px -6% 0px', threshold: 0.06 }
		);

		cards.forEach((card) => io.observe(card));
		cardsRevealObserver = io;
	}

	initProjectCardsReveal();
	document.addEventListener('astro:page-load', initProjectCardsReveal);

	const dialog = document.getElementById('project-modal');
	const titleEl = document.getElementById('project-modal-title');
	const descriptionEl = document.getElementById('project-modal-description');
	const swiperEl = document.getElementById('project-gallery-swiper');
	const wrapper = swiperEl?.querySelector('.swiper-wrapper');
	const closeBtn = dialog?.querySelector('.project-modal__close');

	let swiperInstance = null;

	function destroySwiper() {
		if (swiperInstance) {
			swiperInstance.destroy(true, true);
			swiperInstance = null;
		}
	}

	function openModal(project) {
		if (!dialog || !titleEl || !descriptionEl || !wrapper || !swiperEl) return;

		destroySwiper();
		titleEl.textContent = project.title;
		const desc = project.description ?? '';
		descriptionEl.textContent = desc;
		if (desc) {
			dialog.setAttribute('aria-describedby', 'project-modal-description');
		} else {
			dialog.removeAttribute('aria-describedby');
		}
		wrapper.innerHTML = project.gallery
			.map(
				(src) =>
					`<div class="swiper-slide"><img src="${src.replace(/"/g, '&quot;')}" alt="" loading="eager" decoding="async" /></div>`
			)
			.join('');

		swiperInstance = new Swiper(swiperEl, {
			modules: [Navigation, Pagination, Keyboard, A11y, EffectFade],
			effect: 'fade',
			fadeEffect: { crossFade: true },
			loop: project.gallery.length > 1,
			slidesPerView: 1,
			spaceBetween: 0,
			centeredSlides: false,
			speed: 500,
			watchOverflow: true,
			resistanceRatio: 0,
			autoHeight: true,
			navigation: {
				nextEl: '.swiper-button-next',
				prevEl: '.swiper-button-prev',
			},
			pagination: {
				el: '.swiper-pagination',
				clickable: true,
			},
			keyboard: { enabled: true },
			a11y: {
				enabled: true,
				prevSlideMessage: 'Предишна снимка',
				nextSlideMessage: 'Следваща снимка',
			},
			on: {
				afterInit(swiper) {
					const speed = swiper.params.speed ?? 300;
					const bump = () => swiper.updateAutoHeight(speed);
					swiper.el.querySelectorAll('.swiper-slide img').forEach((img) => {
						if (img.complete) {
							requestAnimationFrame(bump);
						} else {
							img.addEventListener('load', bump, { once: true });
							img.addEventListener('error', bump, { once: true });
						}
					});
					swiper.updateAutoHeight(0);
				},
				slideChangeTransitionEnd(swiper) {
					swiper.updateAutoHeight(swiper.params.speed ?? 300);
				},
			},
		});

		dialog.showModal();
		requestAnimationFrame(() => {
			swiperInstance?.update();
			swiperInstance?.updateAutoHeight(0);
		});
	}

	document.querySelectorAll('.project-card[data-project-id]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const id = btn.getAttribute('data-project-id');
			const project = id ? projectById[id] : null;
			if (project) openModal(project);
		});
	});

	closeBtn?.addEventListener('click', () => {
		destroySwiper();
		dialog?.close();
	});

	dialog?.addEventListener('close', () => {
		destroySwiper();
		if (wrapper) wrapper.innerHTML = '';
		if (descriptionEl) descriptionEl.textContent = '';
		dialog?.removeAttribute('aria-describedby');
	});

	dialog?.addEventListener('click', (e) => {
		const rect = dialog.getBoundingClientRect();
		const inDialog =
			e.clientX >= rect.left &&
			e.clientX <= rect.right &&
			e.clientY >= rect.top &&
			e.clientY <= rect.bottom;
		if (!inDialog) {
			destroySwiper();
			dialog.close();
		}
	});
</script>
