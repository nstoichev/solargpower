---
const videoId = 'TzfnlPxCZv0';
const videoSrc = `https://www.youtube-nocookie.com/embed/${videoId}?autoplay=1&mute=1&controls=0&loop=1&playlist=${videoId}&playsinline=1&rel=0&modestbranding=1&iv_load_policy=3&disablekb=1&fs=0`;
---

<section class="hero">
  <div class="hero__media" aria-hidden="true">
    <iframe
      class="hero__video"
      src={videoSrc}
      title="Solar G Power hero background video"
      loading="eager"
      allow="autoplay; encrypted-media; picture-in-picture"
      referrerpolicy="strict-origin-when-cross-origin"
      tabindex="-1"
    ></iframe>
  </div>

  <div class="hero__content">
    <h1>Добре дошли в Бъдещето!</h1>

    <h4>СОЛАР ДЖИ ПАУЪР ЕООД</h4>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: calc(100vh - var(--site-header-offset));
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: #000;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
    
  }

  .hero__video {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 177.77777778vh;
    height: 56.25vw;
    min-width: 100%;
    min-height: 100%;
    transform: translate(-50%, -50%);
    border: 0;
    pointer-events: none;
    background-attachment: fixed;
  }

  .hero h1 {
    margin-bottom: 20px;
    color: var(--coor-headings);
    text-shadow:
      0 0 12px rgba(255, 255, 255, 0.95),
      0 0 28px rgba(255, 255, 255, 0.65),
      0 2px 4px rgba(255, 255, 255, 0.35);
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .hero__content {
    position: relative;
    color: white;
    z-index: 2;
  }

  @media (min-width: 750px) {
    .hero h1 {
      font-size: 9rem;
    }
  }
</style>