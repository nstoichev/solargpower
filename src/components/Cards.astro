---
const { image, title, richtext, buttonText, buttonUrl } = Astro.props;
---

<div class="card">
  {image && (
    <div class="card-image">
      <img src={image} alt={title} />
    </div>
  )}

  <div class="card-content">
    {title && <h3 class="card-title">{title}</h3>}
    {richtext && (
      <div class="card-text" set:html={richtext} />
    )}

    {buttonText && buttonUrl && (
      <a href={buttonUrl} class="btn btn--outline btn--block">
        {buttonText}
      </a>
    )}
  </div>
</div>

<style is:global>
.card {
  border: 1px solid #e5e5e5;
  overflow: hidden;
  background: white;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  display: flex;
  flex-direction: column;
  height: 100%;
  border-radius: var(--border-radius);
}

.card:hover {
  box-shadow: 0 12px 32px var(--color-primary);
}

.card-image {
  width: 100%;
  padding-bottom: 130%;
  object-fit: cover;
  position: relative;
}

.card-text ol {
  list-style: decimal;
  padding-left: 20px;
  font-weight: 700;
}

.card-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.card-content {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.card-title {
  margin: 0 0 1rem;
}

.card-text {
  margin-bottom: 1rem;
  color: #555;
  flex: 1;
  padding-bottom: 1.5rem;
}

.card-text :where(p, ul, ol) {
  margin: 0 0 0.75rem;
}

.card-text :where(p, ul, ol):last-child {
  margin-bottom: 0;
}
</style>