---
const currentPath = Astro.url.pathname;

const navigationItems = [
	{ label: 'Начало', href: '/', isActive: currentPath === '/' },
	{ label: 'За нас', href: '/za-nas', isActive: currentPath === '/za-nas' },
	{ label: 'Проекти', href: '/proekti', isActive: currentPath === '/proekti' },
	{ label: 'Евро проекти', href: '/evroproekti', isActive: currentPath === '/evroproekti' },
	{ label: 'Контакти', href: '/kontakti', isActive: currentPath === '/kontakti' },
];
---

<header class="site-header" data-site-header>
	<div class="container site-header__inner">
		<a class="site-header__brand" href="/" aria-label="Солар Джи Пауър - Начало">
			<img class="site-header__logo" src="/logo.png" alt="Солар Джи Пауър" />
			<span class="site-header__brand-text visually-hidden">Solar G Power</span>
		</a>

		<nav class="site-header__nav" aria-label="Основна навигация">
			<ul class="site-header__nav-list">
				{
					navigationItems.map((item) => (
						<li>
							<a
								href={item.href}
								class:list={['site-header__nav-link', { 'is-active': item.isActive }]}
								aria-current={item.isActive ? 'page' : undefined}
							>
								{item.label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<button
			class="site-header__menu-button"
			type="button"
			aria-label="Отвори менюто"
			aria-controls="mobile-navigation"
			aria-expanded="false"
			data-menu-button
		>
			<span class="site-header__menu-button-bar"></span>
			<span class="site-header__menu-button-bar"></span>
			<span class="site-header__menu-button-bar"></span>
		</button>
	</div>
</header>

<div class="site-header__overlay" data-menu-overlay aria-hidden="true"></div>

<nav
	id="mobile-navigation"
	class="site-header__drawer"
	aria-label="Мобилна навигация"
	aria-hidden="true"
	data-mobile-drawer
>
	<ul class="site-header__drawer-list">
		{
			navigationItems.map((item, index) => (
				<li style={{ '--drawer-item-index': index }}>
					<a
						href={item.href}
						class:list={['site-header__drawer-link', { 'is-active': item.isActive }]}
						aria-current={item.isActive ? 'page' : undefined}
						data-nav-link
					>
						{item.label}
					</a>
				</li>
			))
		}
	</ul>
</nav>

<script>
	const menuButton = document.querySelector('[data-menu-button]');
	const overlay = document.querySelector('[data-menu-overlay]');
	const drawer = document.querySelector('[data-mobile-drawer]');
	const navLinks = document.querySelectorAll('[data-nav-link]');

	const setMenuState = (isOpen: boolean) => {
		if (!(menuButton instanceof HTMLButtonElement)) return;
		if (!(overlay instanceof HTMLDivElement)) return;
		if (!(drawer instanceof HTMLElement)) return;

		menuButton.setAttribute('aria-expanded', String(isOpen));
		menuButton.setAttribute('aria-label', isOpen ? 'Затвори менюто' : 'Отвори менюто');
		menuButton.classList.toggle('is-open', isOpen);
		overlay.classList.toggle('is-open', isOpen);
		overlay.setAttribute('aria-hidden', String(!isOpen));
		drawer.classList.toggle('is-open', isOpen);
		drawer.setAttribute('aria-hidden', String(!isOpen));
		document.body.classList.toggle('menu-open', isOpen);
	};

	const toggleMenu = () => {
		if (!(drawer instanceof HTMLElement)) return;
		setMenuState(!drawer.classList.contains('is-open'));
	};

	menuButton?.addEventListener('click', toggleMenu);
	overlay?.addEventListener('click', () => setMenuState(false));

	navLinks.forEach((link) => {
		link.addEventListener('click', () => setMenuState(false));
	});

	window.addEventListener('resize', () => {
		if (window.innerWidth > 900) {
			setMenuState(false);
		}
	});
</script>

<style>
	:global(body.menu-open) {
		overflow: hidden;
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 1002;
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: blur(14px);
		border-bottom: 1px solid rgba(17, 17, 17, 0.08);
	}

	.site-header__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2.4rem;
		min-height: 8rem;
	}

	.site-header__brand {
		display: inline-flex;
		align-items: center;
		gap: 1.2rem;
		flex-shrink: 0;
	}

	.site-header__logo {
		width: 6.6rem;
		height: auto;
		object-fit: contain;
	}

	.site-header__brand-text {
		font-size: 2rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
	}

	.site-header__nav {
		margin-left: auto;
	}

	.site-header__nav-list {
		display: flex;
		align-items: center;
		gap: 1.2rem;
	}

	.site-header__nav-link,
	.site-header__drawer-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 1.6rem;
		font-weight: 600;
		padding: 1rem 1.4rem;
		border-radius: 999px;
		transition:
			background-color 0.25s ease,
			color 0.25s ease;
	}

	.site-header__nav-link:hover,
	.site-header__drawer-link:hover,
	.site-header__nav-link:focus-visible,
	.site-header__drawer-link:focus-visible {
		background-color: rgba(45, 194, 107, 0.12);
		color: var(--color-primary);
		outline: none;
	}

	.site-header__nav-link.is-active,
	.site-header__drawer-link.is-active {
		background-color: var(--color-primary);
		color: var(--color-light);
	}

	.site-header__menu-button {
		display: none;
		position: relative;
		align-items: center;
		justify-content: center;
		width: 4.8rem;
		height: 4.8rem;
		border-radius: 50%;
		border: 1px solid rgba(17, 17, 17, 0.12);
		background-color: var(--color-light);
	}

	.site-header__menu-button-bar {
		position: absolute;
		left: 50%;
		width: 2rem;
		height: 0.2rem;
		margin-left: -1rem;
		background-color: var(--color-dark);
		border-radius: 999px;
		transition:
			transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
			opacity 0.25s ease;
	}

	.site-header__menu-button-bar:nth-child(1) {
		transform: translateY(-0.55rem);
	}

	.site-header__menu-button-bar:nth-child(2) {
		transform: translateY(0);
		opacity: 1;
	}

	.site-header__menu-button-bar:nth-child(3) {
		transform: translateY(0.55rem);
	}

	.site-header__menu-button.is-open .site-header__menu-button-bar:nth-child(1) {
		transform: translateY(0) rotate(45deg);
	}

	.site-header__menu-button.is-open .site-header__menu-button-bar:nth-child(2) {
		opacity: 0;
		transform: translateY(0) scaleX(0);
	}

	.site-header__menu-button.is-open .site-header__menu-button-bar:nth-child(3) {
		transform: translateY(0) rotate(-45deg);
	}

	.site-header__overlay {
		position: fixed;
		inset: 0;
		z-index: 1000;
		background: rgba(17, 17, 17, 0.5);
		opacity: 0;
		visibility: hidden;
		pointer-events: none;
		transition:
			opacity 0.35s ease,
			visibility 0s linear 0.35s;
	}

	.site-header__overlay.is-open {
		opacity: 1;
		visibility: visible;
		pointer-events: auto;
		transition:
			opacity 0.35s ease,
			visibility 0s linear 0s;
	}

	.site-header__drawer {
		--drawer-slide-duration: 380ms;
		position: fixed;
		top: 0;
		right: 0;
		z-index: 1001;
		width: min(32rem, 100%);
		height: 100vh;
		padding: 2.4rem;
		padding-top: 2.8rem;
		background: var(--color-light);
		box-shadow: -12px 0 40px rgba(17, 17, 17, 0.18);
		transform: translateX(100%);
		visibility: hidden;
		pointer-events: none;
		transition:
			transform var(--drawer-slide-duration) cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s linear var(--drawer-slide-duration);
	}

	.site-header__drawer.is-open {
		transform: translateX(0);
		visibility: visible;
		pointer-events: auto;
		transition:
			transform var(--drawer-slide-duration) cubic-bezier(0.22, 1, 0.36, 1),
			visibility 0s linear 0s;
	}

	.site-header__drawer-list {
		display: grid;
		gap: 0.4rem;
	}

	.site-header__drawer-list li {
		--drawer-stagger-ms: 70ms;
		transform: translateX(4rem);
		transition: transform 0.58s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.site-header__drawer.is-open .site-header__drawer-list li {
		transform: translateX(0);
		transition-delay: calc(var(--drawer-item-index, 0) * var(--drawer-stagger-ms));
	}

	.site-header__drawer:not(.is-open) .site-header__drawer-list li {
		transition-delay: 0ms;
	}

	.site-header__drawer-link {
		width: 100%;
		justify-content: flex-start;
		font-size: 1.8rem;
		padding: 1.2rem 1.4rem;
		border-radius: 1.4rem;
	}

	@media (max-width: 900px) {
		.site-header__inner {
			min-height: 7.2rem;
		}

		.site-header__nav {
			display: none;
		}

		.site-header__menu-button {
			display: inline-flex;
		}

		.site-header__brand-text {
			font-size: 1.6rem;
		}

		.site-header__overlay {
			top: var(--site-header-offset);
			right: 0;
			bottom: 0;
			left: 0;
			height: auto;
		}

		.site-header__drawer {
			top: var(--site-header-offset);
			height: calc(100dvh - var(--site-header-offset));
			max-height: calc(100vh - var(--site-header-offset));
		}
	}
</style>
